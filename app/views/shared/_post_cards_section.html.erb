<section class="py-16 px-4 md:px-8 max-w-7xl mx-auto">
  <div class="mb-12 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-800 mb-3">
       <%= context == :home ? "Últimas Publicações" : "Todos os Posts" %>
    </h2>
    <p class="text-slate-600">
      Confira nossos artigos mais recentes sobre saúde e bem-estar
    </p>
  </div>

  <% if @posts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <% @posts.each do |post| %>
        <%= render 'shared/post_cards', post: post %>
      <% end %>
    </div>

    <% if context == :home %>
      <div class="text-center">
        <%= link_to "Ver Todos os Posts", posts_path, class: "inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors" %>
      </div>
    <% else %>
      <div class="mt-4">
        <%= paginate @posts %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-12 bg-slate-100 rounded-lg">
      <p class="text-slate-600 mb-4">Nenhum post publicado ainda.</p>
    </div>
  <% end %>
</section>
