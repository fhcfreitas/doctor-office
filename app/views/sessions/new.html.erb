<div class="min-h-screen flex items-center justify-center bg-slate-50">
  <div class="w-full max-w-sm bg-white rounded-2xl shadow-sm border border-slate-200 p-8">

    <div class="mb-8 text-center">
      <h1 class="text-xl font-medium text-slate-800">Área restrita</h1>
      <p class="text-sm text-slate-500 mt-1">Acesso exclusivo ao administrador</p>
    </div>

    <%= form_with url: session_url do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email_address, "E-mail", class: "block text-sm text-slate-600 mb-1" %>
          <%= f.email_field :email_address,
              autofocus: true,
              autocomplete: "email",
              class: "w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
        </div>

        <div>
          <%= f.label :password, "Senha", class: "block text-sm text-slate-600 mb-1" %>
          <%= f.password_field :password,
              autocomplete: "current-password",
              class: "w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
        </div>

        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-slate-300" %>
          <%= f.label :remember_me, "Manter conectado", class: "text-sm text-slate-600" %>
        </div>

        <%= f.submit "Entrar",
            class: "w-full mt-2 bg-slate-800 text-white text-sm font-medium py-2 px-4 rounded-lg hover:bg-slate-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <% if notice.present? %>
      <p class="mt-4 text-sm text-center text-red-500"><%= notice %></p>
    <% end %>
  </div>
</div>
