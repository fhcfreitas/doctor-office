<%= form_with model: [:admin, @post], class: "space-y-6" do |f| %>

  <% if @post.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% @post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Título", class: "block text-sm text-slate-600 mb-1" %>
    <%= f.text_field :title, class: "w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
  </div>

  <div>
    <%= f.label :subtitle, "Subtítulo", class: "block text-sm text-slate-600 mb-1" %>
    <%= f.text_field :subtitle, class: "w-full px-3 py-2 rounded-lg border border-slate-300 text-sm" %>
  </div>

  <div>
    <%= f.label :content, "Conteúdo", class: "block text-sm text-slate-600 mb-1" %>
    <%= f.text_area :content, rows: 12, class: "w-full px-3 py-2 rounded-lg border border-slate-300 text-sm font-mono" %>
  </div>

  <%# Upload de imagem %>
  <div>
    <%= f.label :cover_image, "Imagem de capa", class: "block text-sm text-slate-600 mb-1" %>

    <% if @post.cover_image.attached? %>
      <div class="mb-3">
        <%= image_tag @post.cover_image.variant(resize_to_limit: [400, 200]),
            class: "rounded-lg border border-slate-200" %>
        <label class="flex items-center gap-2 mt-2 text-sm text-slate-500 cursor-pointer">
          <%= f.check_box :remove_cover_image %>
          Remover imagem atual
        </label>
      </div>
    <% end %>

    <%= f.file_field :cover_image,
        accept: "image/png,image/jpeg,image/webp",
        class: "block w-full text-sm text-slate-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200" %>
    <p class="mt-1 text-xs text-slate-400">PNG, JPG ou WebP • máx 5MB</p>
  </div>

  <div class="flex items-center gap-6">
    <label class="flex items-center gap-2 text-sm text-slate-600 cursor-pointer">
      <%= f.check_box :newsletter_flag, class: "rounded border-slate-300" %>
      Incluir na newsletter
    </label>

    <label class="flex items-center gap-2 text-sm text-slate-600 cursor-pointer">
      <%= f.check_box :draft, class: "rounded border-slate-300" %>
      Salvar como rascunhoc
    </label>
  </div>

  <div class="flex gap-3">
    <%= f.submit @post.new_record? ? "Criar post" : "Salvar alterações",
        class: "bg-slate-800 text-white text-sm px-5 py-2 rounded-lg hover:bg-slate-700 transition-colors cursor-pointer" %>

    <%= link_to "Cancelar", admin_root_path, class: "text-sm text-slate-500 hover:text-slate-700 py-2" %>
  </div>

<% end %>
