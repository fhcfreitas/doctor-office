<div class="max-w-3xl mx-auto">

  <div class="mb-6 flex items-center justify-between">
    <div>
      <p class="text-xs text-slate-400 uppercase tracking-wide mb-1">Posts</p>
      <h1 class="text-xl font-medium text-slate-800 line-clamp-1"><%= @post.title %></h1>
    </div>
    <%= link_to admin_posts_path,
        class: "flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 shrink-0" do %>
      ← Voltar para posts
    <% end %>
  </div>

  <%# Status bar %>
  <div class="flex flex-wrap items-center gap-2 mb-6">
    <% if @post.draft? %>
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>
        Rascunho
      </span>
    <% else %>
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
        Publicado
      </span>
    <% end %>

    <% if @post.newsletter_flag? %>
      <% if @post.newsletter_sent? %>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-500 border border-slate-200">
          ✓ Newsletter enviada
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
          Incluído na newsletter
        </span>
      <% end %>
    <% end %>

    <span class="text-xs text-slate-400 ml-auto">
      Criado <%= @post.created_at.strftime("%d/%m/%Y às %H:%M") %>
      <% if @post.published_at.present? %>
        · Publicado <%= @post.published_at.strftime("%d/%m/%Y às %H:%M") %>
      <% end %>
    </span>
  </div>

  <%# Imagem de capa %>
  <% if @post.cover_image.attached? %>
    <div class="mb-6 rounded-xl overflow-hidden border border-slate-200 flex justify-center">
      <%= image_tag @post.cover_image.variant(resize_to_limit: [400, 200]),
          alt: @post.title,
          class: "w-48 object-cover" %>
    </div>
  <% end %>

  <%# Conteúdo %>
  <div class="bg-white rounded-2xl border border-slate-200 p-8 mb-6">
    <% if @post.subtitle.present? %>
      <p class="text-base text-slate-500 mb-4"><%= @post.subtitle %></p>
    <% end %>

    <div class="prose prose-slate max-w-none text-sm leading-relaxed whitespace-pre-wrap">
      <%= @post.content %>
    </div>
  </div>

  <%# Ações %>
  <div class="flex flex-wrap items-center gap-3">
    <%= link_to "Editar post", edit_admin_post_path(@post),
        class: "bg-slate-800 text-white text-sm px-5 py-2 rounded-lg hover:bg-slate-700 transition-colors" %>

    <% if @post.draft? %>
      <%= button_to "Publicar agora", publish_admin_post_path(@post), method: :patch,
          class: "bg-green-600 text-white text-sm px-5 py-2 rounded-lg hover:bg-green-700 transition-colors cursor-pointer" %>
    <% end %>

    <%= button_to "Excluir", admin_post_path(@post), method: :delete,
        data: { turbo_confirm: "Tem certeza? Essa ação não pode ser desfeita." },
        class: "text-sm text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer ml-auto" %>
  </div>

</div>
