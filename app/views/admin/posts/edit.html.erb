<div class="max-w-3xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <p class="text-xs text-slate-400 uppercase tracking-wide mb-1">Posts</p>
      <h1 class="text-xl font-medium text-slate-800">Editar post</h1>
    </div>
    <div class="flex items-center gap-4">
      <%= link_to "Ver post", admin_post_path(@post),
          class: "text-sm text-slate-500 hover:text-slate-700" %>
      <%= link_to admin_posts_path,
          class: "text-sm text-slate-500 hover:text-slate-700" do %>
        ← Voltar
      <% end %>
    </div>
  </div>

  <%= render "post_form" %>
</div>
