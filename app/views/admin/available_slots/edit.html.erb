<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black/30 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-slate-800">Editar slot</h2>
        <% unless @slot.booked? %>
          <%= button_to admin_available_slot_path(@slot, week_offset: params[:week_offset]),
                method: :delete,
                class: "text-xs text-red-500 hover:text-red-700" do %>
            Cancelar slot
          <% end %>
        <% end %>
      </div>
      <%= render "form", slot: @slot, week_offset: params[:week_offset] %>
    </div>
  </div>
<% end %>
