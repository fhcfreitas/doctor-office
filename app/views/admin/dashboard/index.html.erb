<div class="space-y-8">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-slate-800">Dashboard</h1>
      <p class="text-sm text-slate-500 mt-1">
        Bem-vindo, <%= @session.user.name %>
      </p>
    </div>
  </div>

  <%# Grid de cards %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%# Card — Posts %>
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 space-y-6">

      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-base font-semibold text-slate-700">Posts</h2>
          <p class="text-sm text-slate-400 mt-0.5">Gerencie o conteúdo do blog</p>
        </div>
        <div class="bg-slate-100 rounded-xl p-2">
          <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
          </svg>
        </div>
      </div>

     <div class="grid grid-cols-3 gap-2 md:gap-3">
       <%= link_to admin_posts_path do %>
          <div class="bg-slate-50 border border-slate-100 rounded-xl px-2 py-2 md:px-4 md:py-3 text-center hover:bg-slate-100 transition">
            <p class="text-lg md:text-2xl font-semibold text-slate-800"><%= @posts_count %></p>
            <p class="text-[10px] md:text-xs text-slate-400 mt-0.5">Total</p>
          </div>
        <% end %>

        <%= link_to admin_posts_path(filter: "published") do %>
          <div class="bg-green-50 border border-green-100 rounded-xl px-2 py-2 md:px-4 md:py-3 text-center">
            <p class="text-lg md:text-2xl font-semibold text-green-700"><%= @published_posts_count %></p>
            <p class="text-[10px] md:text-xs text-green-500 mt-0.5">Publicados</p>
          </div>
        <% end %>

        <%= link_to admin_posts_path(filter: "draft") do %>
          <div class="bg-amber-50 border border-amber-100 rounded-xl px-2 py-2 md:px-4 md:py-3 text-center">
            <p class="text-lg md:text-2xl font-semibold text-amber-700"><%= @draft_posts_count %></p>
            <p class="text-[10px] md:text-xs text-amber-500 mt-0.5">Rascunhos</p>
          </div>
        <% end %>
      </div>

      <div class="flex flex-col sm:flex-row gap-2 pt-2 border-t border-slate-100">
        <%= link_to new_admin_post_path,
            class: "flex-1 text-center text-sm font-medium bg-slate-800 text-white rounded-lg py-2 px-4 hover:bg-slate-700 transition-colors" do %>
          + Novo post
        <% end %>
        <%= link_to admin_posts_path,
            class: "flex-1 text-center text-sm font-medium border border-slate-200 text-slate-600 rounded-lg py-2 px-4 hover:bg-slate-50 transition-colors" do %>
          Ver todos
        <% end %>
      </div>

    </div>

    <%# Card — Agendamentos %>
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 space-y-6">

      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-base font-semibold text-slate-700">Agendamentos</h2>
          <p class="text-sm text-slate-400 mt-0.5">Consultas e disponibilidade</p>
        </div>
        <div class="bg-slate-100 rounded-xl p-2">
          <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/>
          </svg>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-2 md:gap-3">
        <div class="bg-slate-50 border border-slate-100 rounded-xl px-2 py-2 md:px-4 md:py-3 text-center">
          <p class="text-lg md:text-2xl font-semibold text-slate-800"></p>
          <p class="text-[10px] md:text-xs text-slate-400 mt-0.5">Total</p>
        </div>
        <div class="bg-blue-50 border border-blue-100 rounded-xl px-2 py-2 md:px-4 md:py-3 text-center">
           <p class="text-lg md:text-2xl font-semibold text-blue-700"></p>
           <p class="text-[10px] md:text-xs text-blue-500 mt-0.5">Hoje</p>
        </div>
        <div class="bg-orange-50 border border-orange-100 rounded-xl px-2 py-2 md:px-4 md:py-3 text-center">
          <p class="text-lg md:text-2xl font-semibold text-orange-700"></p>
          <p class="text-[10px] md:text-xs text-orange-500 mt-0.5">Pendentes</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-2 pt-2 border-t border-slate-100">
        <%= link_to '#',
            class: "flex-1 text-center text-sm font-medium bg-slate-800 text-white rounded-lg py-2 px-4 hover:bg-slate-700 transition-colors" do %>
          Ver agendamentos
        <% end %>
        <%= link_to '#',
            class: "flex-1 text-center text-sm font-medium border border-slate-200 text-slate-600 rounded-lg py-2 px-4 hover:bg-slate-50 transition-colors" do %>
          Gerenciar agenda
        <% end %>
      </div>

    </div>

  </div>
</div>
